# Backend
PORT=3001
AGENT_TIMEOUT=600000

# LLM API Key -- proxy 转发给 MiniMax，SDK 作为 ANTHROPIC_API_KEY 读取
# 优先使用 MINIMAX_API_KEY；若未设置则回退到 ANTHROPIC_API_KEY
MINIMAX_API_KEY=your_minimax_api_key_here
ANTHROPIC_API_KEY=

# GitHub (optional, for github MCP server -- public repos work without it)
GITHUB_TOKEN=
