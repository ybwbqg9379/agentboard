# ===========================================
# AgentBoard Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# The proxy translates Anthropic API format to OpenAI format,
# so any OpenAI-compatible LLM service works out of the box.

# --- LLM Configuration (required) ---

# Base URL of any OpenAI-compatible API endpoint
# Examples:
#   OpenAI:        https://api.openai.com/v1
#   DeepSeek:      https://api.deepseek.com/v1
#   Moonshot:      https://api.moonshot.cn/v1
#   Together:      https://api.together.xyz/v1
#   Groq:          https://api.groq.com/openai/v1
#   Ollama:        http://localhost:11434/v1
#   vLLM:          http://localhost:8000/v1
#   LM Studio:     http://localhost:1234/v1
#   Any compatible: https://your-provider.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# API key for the LLM provider
LLM_API_KEY=sk-your-api-key-here

# Model name (must be available at the provider above)
LLM_MODEL=gpt-4o-mini

# --- Backend ---
PORT=3001
PROXY_PORT=4000
AGENT_TIMEOUT=600000

# --- Authentication (optional) ---
# Set to enable API key auth for the AgentBoard API itself
# AGENTBOARD_API_KEY=

# --- GitHub (optional) ---
# For the GitHub MCP server; public repos work without it
# GITHUB_TOKEN=

# ===========================================
# Web Search & Crawling MCP Servers
# ===========================================
# Each key below enables a corresponding MCP server.
# Servers only activate when their API key is present.
# The Fetch MCP server requires no key and is always on.

# --- Tavily (recommended: AI-optimized search) ---
# Free 1K queries/month. Sign up: https://tavily.com
# TAVILY_API_KEY=tvly-your-key-here

# --- Firecrawl (recommended: web scraping & crawling) ---
# Free 500 pages/month. Sign up: https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-your-key-here

# --- Jina AI Reader (recommended: URL→Markdown, search) ---
# Best token efficiency. Free tier at https://jina.ai
# JINA_API_KEY=jina_your-key-here
# Optional: override the default remote MCP endpoint
# JINA_MCP_ENDPOINT=https://mcp.jina.ai/v1

# --- Exa AI (neural semantic search) ---
# Free tier. Sign up: https://exa.ai
# EXA_API_KEY=your-exa-key-here

# --- Brave Search (privacy-first web search) ---
# Free 2K queries/month. Sign up: https://brave.com/search/api/
# BRAVE_API_KEY=your-brave-key-here

# --- Remote Browser (optional) ---
# Override local Playwright with a remote browser cluster
# MCP_BROWSER_ENDPOINT=
# MCP_BROWSER_TOKEN=
