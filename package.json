{
  "name": "agentboard",
  "version": "0.15.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:backend": "cd backend && node --env-file=../.env.local --watch server.js",
    "dev:frontend": "cd frontend && npx vite",
    "dev:proxy": "cd backend && node --env-file=../.env.local proxy.js",
    "dev": "npx concurrently -n proxy,back,front -c yellow,blue,green \"npm run dev:proxy\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npx vite build",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint backend/ frontend/src/",
    "lint:strict": "npx eslint --max-warnings 0 backend/ frontend/src/",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npx vitest run",
    "test:frontend": "cd frontend && npx vitest run",
    "check": "npm run format:check && npm run lint:strict && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "playwright": "^1.59.0"
  }
}
